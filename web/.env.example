# Copy to .env.local and fill in. All optional — the site runs on mock data
# and a simulated booking flow until these are provided.

# Supabase (DB + Auth + Storage) — https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — bypasses RLS, used by the admin panel. Never prefix NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Booking alerts to admin Telegram (optional). Create a bot via @BotFather,
# then get the chat id (e.g. message @userinfobot). Empty = notifications off.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Yandex Maps JS API key — route map rendering. https://developer.tech.yandex.ru/
NEXT_PUBLIC_YANDEX_MAPS_KEY=
# Mapbox public token (pk....) — admin place-search autocomplete (geocoding) only.
# Free tier; create at https://account.mapbox.com → Tokens. Public (client-side).
NEXT_PUBLIC_MAPBOX_TOKEN=

# Public site origin, used for SEO canonical/sitemap URLs.
NEXT_PUBLIC_SITE_URL=https://hayasatours.com

# ── Business identity for SEO / LocalBusiness schema (fill before launch) ──
# Real NAP (Name-Address-Phone) feeds the TravelAgency JSON-LD + local pack.
# Address/geo stay OUT of schema until set here (we never publish a fake address).
# Phone/email come from /admin → Content (site_content) or lib/contact.ts defaults.
NEXT_PUBLIC_BUSINESS_STREET=
NEXT_PUBLIC_BUSINESS_POSTAL=
NEXT_PUBLIC_BUSINESS_CITY=Yerevan
# Office coordinates (5-decimal precision), e.g. 40.17720 / 44.50350
NEXT_PUBLIC_BUSINESS_LAT=
NEXT_PUBLIC_BUSINESS_LNG=
# Opening hours for schema (defaults 09:00–21:00 if unset)
NEXT_PUBLIC_BUSINESS_OPENS=
NEXT_PUBLIC_BUSINESS_CLOSES=

# Authoritative profile URLs → schema "sameAs" (entity resolution for Google + AI).
# Set once the accounts exist; critical for AI citation confidence.
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_TRIPADVISOR_URL=
